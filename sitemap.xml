---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {% for post in site.posts %}
    {% assign include_post = true %}
    {% if post.draft or post.sitemap == false or post.i18n_fallback %}
      {% assign include_post = false %}
    {% endif %}
    {% if include_post %}
      <url>
        <loc>{{ site.url }}{{ post.url }}</loc>
        {% if post.translation_key %}
          {% assign alternates = site.posts | concat: site.pages | where: "translation_key", post.translation_key %}
          {% for alternate in alternates %}
            {% if alternate.lang and alternate.sitemap != false %}
              {% assign alternate_i18n = site.data.i18n[alternate.lang] %}
        <xhtml:link rel="alternate" hreflang="{{ alternate_i18n.locale_tag | default: alternate.lang }}" href="{{ site.url }}{{ alternate.url }}" />
            {% endif %}
          {% endfor %}
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/-/{{ post.i18n_path | remove_first: '/' }}" />
        {% endif %}
        <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
      </url>
    {% endif %}
  {% endfor %}
  
  {% for page in site.pages %}
    {% assign include_page = true %}
    {% if page.url contains '/404' %}
      {% assign include_page = false %}
    {% endif %}
    {% if page.url contains '/feed' %}
      {% assign include_page = false %}
    {% endif %}
    {% if page.url contains '/sitemap' %}
      {% assign include_page = false %}
    {% endif %}
    {% if page.sitemap == false or page.i18n_fallback %}
      {% assign include_page = false %}
    {% endif %}
    {% if include_page %}
      <url>
        <loc>{{ site.url }}{{ page.url }}</loc>
        {% if page.translation_key %}
          {% assign alternates = site.posts | concat: site.pages | where: "translation_key", page.translation_key %}
          {% for alternate in alternates %}
            {% if alternate.lang and alternate.sitemap != false %}
              {% assign alternate_i18n = site.data.i18n[alternate.lang] %}
        <xhtml:link rel="alternate" hreflang="{{ alternate_i18n.locale_tag | default: alternate.lang }}" href="{{ site.url }}{{ alternate.url }}" />
            {% endif %}
          {% endfor %}
        <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}/-/{{ page.i18n_path | remove_first: '/' }}" />
        {% endif %}
        {% if page.last_modified_at %}
          <lastmod>{{ page.last_modified_at | date_to_xmlschema }}</lastmod>
        {% endif %}
        <changefreq>weekly</changefreq>
        {% if page.url == '/' %}
          <priority>1.0</priority>
        {% else %}
          <priority>0.6</priority>
        {% endif %}
      </url>
    {% endif %}
  {% endfor %}
</urlset> 